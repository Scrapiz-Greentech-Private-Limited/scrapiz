{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "credentialsSource": "local"
      },
      "ios": {
        "credentialsSource": "remote"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "credentialsSource": "local"
      },
      "ios": {
        "credentialsSource": "remote"
      }
    },
    "production":{
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "environment": "production",
      "android": {
        "credentialsSource": "local"
      }
    },
    "production-ios": {
      "distribution": "store",
      "channel": "production-ios",
      "autoIncrement": true,
      "environment": "production",
      "ios": {
        "credentialsSource": "remote"
      }
    },
    "production-android": {
      "distribution": "store",
      "channel": "production-android",
      "autoIncrement": true,
      "environment": "production",
      "android": {
        "credentialsSource": "local"
      }
    }
  },
  "submit": {
    "production-ios": {},
    "production-android": {},
    "production": {}
  }
}

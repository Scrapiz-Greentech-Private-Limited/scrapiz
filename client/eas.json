{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "credentialsSource":"local",
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "credentialsSource":"local",
      "environment":"production",
      "channel":"production"
    }
  },
  "submit": {
    "production": {}
  }
}

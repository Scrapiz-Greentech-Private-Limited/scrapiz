{
  "expo": {
    "name": "Scrapiz",
    "slug": "Scrapiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/scrapiz.jpg",
    "scheme": "com.scrapiz.app",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scrapiz.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "launchMode": "singleTask",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/scrapiz.jpg",
        "backgroundColor": "#ffffff"
      },
      "splash": {
        "image": "./assets/images/scrapiz.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "package": "com.scrapiz.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/scrapiz.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-location",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/scrapiz.jpg",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Montserrat-Regular.ttf",
            "./assets/fonts/YoungSerif-Regular.ttf"
          ]
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "env": {
        "EXPO_PUBLIC_API_URL": "http://13.204.50.150/api",
        "EXPO_PUBLIC_FRONTEND_SECRET": "Scrapiz#0nn$(tab!z",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "765250017313-94tside5h04tidg35gahkevddopjr74l.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "765250017313-m05cng47dvaisjc3gnoo2fkvifsv5q30.apps.googleusercontent.com"
      },
      "router": {},
      "eas": {
        "projectId": "ecd7e0de-6b00-4bb9-acde-8dda52a2fd22"
      }
    }
  }
}

{
  "expo": {
    "name": "Scrapiz",
    "slug": "Scrapiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "@/assets/images/scrapiz.jpg",
    "scheme": "Scrapiz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "@/assets/images/scrapiz.jpg",
        "backgroundColor": "#ffffff"
      },
      "splash": {
        "image": "@/assets/images/scrapiz.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "package": "com.anonymous.Scrapiz"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "@/assets/images/scrapiz.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "image": "@/assets/images/scrapiz.jpg",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "@/assets/fonts/Montserrat-Regular.ttf",
            "@/assets/fonts/YoungSerif-Regular.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.104:8000/api",
        "EXPO_PUBLIC_FRONTEND_SECRET": "Scrapiz#0nn$(tab!z"
      }
    }
  }
}

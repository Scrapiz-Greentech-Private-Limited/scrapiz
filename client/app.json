{
  "expo": {
    "name": "Scrapiz",  
    "slug": "scrapiz-client",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/newapp.png",
    "scheme": "com.scrapiz.app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/newapp.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.scrapiz.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Scrapiz needs your location to check service availability and provide accurate scrap pickup rates in your area.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Scrapiz needs your location to check service availability and provide accurate scrap pickup rates in your area.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.515246444918-9i1en7elr36ogmjimmsu0durj7cr0aai"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "splash": {
        "image": "./assets/images/newapp.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/foreground5.png",
        "backgroundColor": "#16a34a"
      },
      "splash": {
        "image": "./assets/images/newapp.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET"
      ],
      "package": "com.scrapiz.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 55
    },
    "notification": {
      "icon": "./assets/images/foreground5.png",
      "color": "#16a34a"
    },
    "web": {
      "supportedPlatforms": []
    },
    "plugins": [
  "expo-router",
  "expo-apple-authentication",
  "expo-image-picker",

  [
    "expo-build-properties",
    {
      "android": {
        "compileSdkVersion": 36,
        "targetSdkVersion": 36,
        "ndkVersion": "26.1.10909125"
      }
    }
  ],

  [
    "expo-secure-store",
    {
      "configureAndroidBackup": true,
      "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
    }
  ],

  [
    "expo-location",
    {
      "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
    }
  ],

  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splashScreen.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/images/splashScreen.png",
        "backgroundColor": "#121212"
      }
    }
  ],

  [
    "expo-font",
    {
      "fonts": [
        "./assets/fonts/Montserrat-Regular.ttf",
        "./assets/fonts/YoungSerif-Regular.ttf"
      ]
    }
  ],

  "expo-localization",

  [
    "@rnmapbox/maps",
    {
      "RNMapboxMapsImpl": "mapbox",
      "MBXAccessToken": "pk.eyJ1IjoiYXlhYW5hbWphZCIsImEiOiJjbWhxbW1veHcwdnB2MmpzNDA2emo1aWp3In0.Mc5kN89_lqGeagn5jWvvzA"
    }
  ]
],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.scrapiz.in/api",
        "EXPO_PUBLIC_FRONTEND_SECRET": "Scrapiz#0nn$(tab!z",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "515246444918-9i1en7elr36ogmjimmsu0durj7cr0aai.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID_V2": "515246444918-vcupmtbkchia1qrqtp4sr6ge1qkkvlur.apps.googleusercontent.com",
        "EXPO_PUBLIC_MAP_TILER_API_KEY": "oEldgWNaTPZsPFgr6fab",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "AIzaSyCXv6HR4agCc7eHo02CjVgN4yMVxbvQRqg",
        "EXPO_PUBLIC_ENABLE_LOCATION_SKIP": "true"
      },
      "router": {},
      "eas": {
        "projectId": "53993ab9-a554-4468-bbb9-e825c5646e77"
      }
    },
    "runtimeVersion": {
      "policy":"appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/53993ab9-a554-4468-bbb9-e825c5646e77",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "owner": "scrapiz"
  }
}

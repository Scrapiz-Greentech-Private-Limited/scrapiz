{
  "expo": {
    "name": "Scrapiz",
    "slug": "Scrapiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/scrapiz.jpg",
    "scheme": [
      "scrapiz"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scrapiz.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "launchMode": "singleTask",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/scrapiz.jpg",
        "backgroundColor": "#ffffff"
      },
      "splash": {
        "image": "./assets/images/scrapiz.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.AMD_RECORD_AUDIO",
        "android.permission.DETECT_SCREEN_CAPTURE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.scrapiz.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/scrapiz.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-location",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/scrapiz.jpg",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "enableFullScreenImage_legacy": true
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Montserrat-Regular.ttf",
            "./assets/fonts/YoungSerif-Regular.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.104:8000/api",
        "EXPO_PUBLIC_FRONTEND_SECRET": "Scrapiz#0nn$(tab!z"
      },
      "router": {},
      "eas": {
        "projectId": "ecd7e0de-6b00-4bb9-acde-8dda52a2fd22"
      }
    }
  }
}
